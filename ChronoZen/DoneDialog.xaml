<Window x:Class="ChronoZen.DoneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer terminé" Height="200" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1c1c26"
        FontFamily="Segoe UI">
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBlock x:Name="TitleBlock"
               Text="⏰  Timer terminé !"
               Foreground="#c8a96e"
               FontFamily="Segoe UI Light"
               FontSize="16"
               TextAlignment="Center"
               Margin="0,0,0,24"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
      <Button x:Name="BtnSnooze" Content="💤  Snooze +5 min"
              Width="130" Height="40" Margin="6,0"
              Background="#c8a96e" Foreground="#0e0e12"
              BorderThickness="0" Cursor="Hand"
              FontFamily="Segoe UI Semibold" FontSize="10"
              Click="BtnSnooze_Click"/>
      <Button x:Name="BtnPause" Content="☕  Pause"
              Width="100" Height="40" Margin="6,0"
              Background="#6ec8b4" Foreground="#0e0e12"
              BorderThickness="0" Cursor="Hand"
              FontFamily="Segoe UI Semibold" FontSize="10"
              Click="BtnPause_Click"/>
      <Button x:Name="BtnClose" Content="✕ Fermer"
              Width="80" Height="40" Margin="6,0"
              Background="#2a2a36" Foreground="#e8e4da"
              BorderThickness="0" Cursor="Hand"
              FontFamily="Segoe UI Semibold" FontSize="10"
              Click="BtnClose_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
